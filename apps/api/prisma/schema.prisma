generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  email              String     @unique
  fullName           String
  password           String
  mustChangePassword Boolean    @default(false)
  status             UserStatus @default(ACTIVE)

  roles UserRole[]

  followUpSessionsAsTherapist FollowUpSession[] @relation("FollowUpSessionTherapist")

  parentAssignments    ParentPatient[]
  therapistAssignments PatientTherapist[]
  schoolAssignments    SchoolPatient[]

  followUpsAsTherapist FollowUp[]

  objectivesCreated ObjectiveBank[]

  patientDocumentsUploaded PatientDocument[] @relation("PatientDocumentUploader")

  announcementsCreated Announcement[] @relation("AnnouncementAuthor")

  paymentsCreated Payment[] @relation("PaymentCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id   String  @id @default(uuid()) @db.Uuid
  key  RoleKey @unique
  name String

  users UserRole[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RoleKey {
  SUPERADMIN
  ADMIN
  THERAPIST
  PARENT
  FINANCE
  SCHOOL
  SECRETARY
}

model Patient {
  id        String    @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String
  birthDate DateTime?
  notes     String?
  center    GidiCenter @default(SAN_AGUSTIN)

  // Configuración de cobro (mensualidad por frecuencia + descuento opcional).
  sessionsPerWeek Int?
  discountPercent Int? @default(0)

  parents     ParentPatient[]
  assignments PatientTherapist[]
  schools     SchoolPatient[]

  followUps FollowUp[]
  documents PatientDocument[]
  payments  Payment[]

  appointmentRequests AppointmentRequest[]

  patientObjectives PatientObjective[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GidiCenter {
  SAN_AGUSTIN
  VALLARTA
}

enum PatientDocumentCategory {
  EVALUACION
  REVALUACION
  SEGUIMIENTO_PADRES
}

model PatientDocument {
  id           String                  @id @default(uuid()) @db.Uuid
  patientId    String                  @db.Uuid
  category     PatientDocumentCategory
  fileName     String
  mimeType     String
  dataUrl      String                  @db.Text
  uploadedById String                  @db.Uuid

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("PatientDocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([category])
}

model PatientTherapist {
  id          String @id @default(uuid()) @db.Uuid
  patientId   String @db.Uuid
  therapistId String @db.Uuid

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User    @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([patientId, therapistId])
  @@index([patientId])
  @@index([therapistId])
}

model ParentPatient {
  id        String @id @default(uuid()) @db.Uuid
  parentId  String @db.Uuid
  patientId String @db.Uuid

  relationship GuardianRelationship @default(OTHER)
  isPrimary    Boolean              @default(false)
  notes        String?

  parent  User    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([parentId, patientId])
  @@index([patientId])
  @@index([parentId])
}

enum GuardianRelationship {
  MOTHER
  FATHER
  TUTOR
  OTHER
}

model SchoolPatient {
  id        String  @id @default(uuid()) @db.Uuid
  schoolId  String  @db.Uuid
  patientId String  @db.Uuid
  notes     String?

  school  User    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([schoolId, patientId])
  @@index([patientId])
  @@index([schoolId])
}

enum AreaTrackingMode {
  TEXT_ONLY
  MONTHLY_GRID
}

model Area {
  id        String  @id @default(uuid()) @db.Uuid
  key       String  @unique
  name      String
  category  String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  trackingMode AreaTrackingMode @default(MONTHLY_GRID)

  followUps     FollowUp[]
  objectiveBank ObjectiveBank[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ObjectiveBank {
  id          String  @id @default(uuid()) @db.Uuid
  description String
  areaId      String  @db.Uuid
  creatorId   String  @db.Uuid
  isPublic    Boolean @default(false)

  area    Area @relation(fields: [areaId], references: [id], onDelete: Restrict)
  creator User @relation(fields: [creatorId], references: [id], onDelete: Restrict)

  patientLinks PatientObjective[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([areaId])
  @@index([creatorId])
  @@index([isPublic])
}

model PatientObjective {
  id              String @id @default(uuid()) @db.Uuid
  patientId       String @db.Uuid
  objectiveBankId String @db.Uuid

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  objectiveBank ObjectiveBank @relation(fields: [objectiveBankId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, objectiveBankId])
  @@index([patientId])
  @@index([objectiveBankId])
}

model FollowUp {
  id          String @id @default(uuid()) @db.Uuid
  patientId   String @db.Uuid
  therapistId String @db.Uuid
  areaId      String @db.Uuid

  periodYear  Int
  periodMonth Int

  generalGoal  String?
  generalNotes String?
  homeWork     String?
  parentComments String?
  observationsAuthor String?

  // Audiencia: a quién se publica el seguimiento (el admin siempre ve).
  visibleToParent    Boolean @default(true)
  visibleToTherapist Boolean @default(true)
  visibleToSchool    Boolean @default(false)

  status FollowUpStatus @default(DRAFT)

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User    @relation(fields: [therapistId], references: [id], onDelete: Restrict)
  area      Area    @relation(fields: [areaId], references: [id], onDelete: Restrict)

  objectives  FollowUpObjective[]
  sessions    FollowUpSession[]
  attachments FollowUpAttachment[]
  metrics     FollowUpMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([patientId, areaId, periodYear, periodMonth])
  @@index([therapistId])
  @@index([areaId])
  @@index([periodYear, periodMonth])
}

enum FollowUpStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model FollowUpObjective {
  id         String @id @default(uuid()) @db.Uuid
  followUpId String @db.Uuid
  idx        Int
  text       String

  monthlyNotes String?

  followUp FollowUp       @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  marks    FollowUpMark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([followUpId, idx])
  @@index([followUpId])
}

/// Sesión real de asistencia dentro de un seguimiento mensual
model FollowUpSession {
  id          String   @id @default(uuid()) @db.Uuid
  followUpId  String   @db.Uuid
  therapistId String   @db.Uuid
  sessionDate DateTime

  followUp  FollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  therapist User     @relation("FollowUpSessionTherapist", fields: [therapistId], references: [id], onDelete: Restrict)
  marks     FollowUpMark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([followUpId, sessionDate])
  @@index([followUpId])
  @@index([sessionDate])
  @@index([therapistId])
}

enum FollowUpMarkCode {
  A
  V
  E
  F
  R
  X
  OK
}

model FollowUpMark {
  id                String @id @default(uuid()) @db.Uuid
  followUpSessionId String @db.Uuid
  objectiveId       String @db.Uuid
  code              FollowUpMarkCode?
  progressScale     Int?
  note              String?

  session   FollowUpSession   @relation(fields: [followUpSessionId], references: [id], onDelete: Cascade)
  objective FollowUpObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([followUpSessionId, objectiveId])
  @@index([objectiveId])
  @@index([followUpSessionId])
}

model FollowUpAttachment {
  id         String  @id @default(uuid()) @db.Uuid
  followUpId String  @db.Uuid
  fileName   String
  mimeType   String
  url        String
  notes      String?

  followUp FollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([followUpId])
}

model FollowUpMetric {
  id         String   @id @default(uuid()) @db.Uuid
  followUpId String   @db.Uuid
  name       String
  value      Float
  unit       String?
  measuredAt DateTime @default(now())
  notes      String?

  followUp FollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)

  @@index([followUpId])
  @@index([name])
  @@index([measuredAt])
}

model AppointmentRequest {
  id            String    @id @default(uuid()) @db.Uuid
  parentPhone   String
  patientId     String?   @db.Uuid
  requestedDate DateTime?
  status        String?   @default("pending")
  rawMessage    String?
  createdAt     DateTime  @default(now())

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  PARCIAL
  DEUDA
}

/// Mensualidad de un paciente por mes.
model Payment {
  id          String @id @default(uuid()) @db.Uuid
  patientId   String @db.Uuid
  periodYear  Int
  periodMonth Int

  /// Monto esperado del mes (mensualidad - descuento, o proporcional). En pesos.
  amountDue  Int
  /// Monto efectivamente pagado. En pesos.
  amountPaid Int           @default(0)
  status     PaymentStatus @default(PENDIENTE)

  paidAt    DateTime?
  method    String?
  reference String?
  notes     String?

  /// Comprobante de pago subido por el papá (data URL).
  receiptUrl        String?   @db.Text
  receiptName       String?
  receiptUploadedAt DateTime?

  createdById String? @db.Uuid

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, periodYear, periodMonth])
  @@index([patientId])
  @@index([periodYear, periodMonth])
  @@index([status])
}

/// Avisos generales publicados por administración a uno o varios roles.
model Announcement {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  body        String    @db.Text
  /// Roles que pueden ver el aviso. Vacío = todos los roles.
  audience    RoleKey[] @default([])
  isActive    Boolean   @default(true)
  createdById String    @db.Uuid

  createdBy User @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model WhatsAppContactState {
  id               String   @id @default(uuid()) @db.Uuid
  waId             String   @unique
  welcomeMenuShown Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
